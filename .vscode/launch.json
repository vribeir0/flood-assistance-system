{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "FLASK_ENV": "development"
            },
            "jinja": true,
            "console": "integratedTerminal"
        }
    ]
}