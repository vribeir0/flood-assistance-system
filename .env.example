FLASK_ENV=development

# CORS — origens permitidas pelo backend (separadas por vírgula)
# Em produção: apenas o domínio do frontend
# Em desenvolvimento: http://localhost ou http://localhost:8081
ALLOWED_ORIGINS=http://localhost

#Captcha
EXPO_PUBLIC_TURNSTILE_SITE_KEY=

# Google Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Maps API
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_URL=https://maps.googleapis.com/maps/api/directions/json

# Weather API
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# MCP Server
SERVER_PATH=server.py
